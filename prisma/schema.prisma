generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id
  email      String       @unique
  avatarUrl  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  plan       Plan         @default(FREE)
  first_name String?
  last_name  String?
  username   String?      @unique
  reviews    Review[]
  trips      Trip[]
  trophies   UserTrophy[]
}

model Trip {
  id             String          @id @default(cuid())
  userId         String
  title          String
  destination    String
  tripType       TripType
  status         TripStatus      @default(GENERATING)
  startDate      DateTime?
  endDate        DateTime?
  numberOfDays   Int
  budgetLevel    BudgetLevel
  totalBudget    Float?
  budgetPerDay   Float?
  aiPrompt       String?
  aiModel        String?
  generatedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  days           Day[]
  hotel          Hotel?
  review         Review?
  transportation Transportation?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Day {
  id         String     @id @default(cuid())
  tripId     String
  dayNumber  Int
  date       DateTime?
  summary    String?
  dailyCost  Float?
  notes      String?
  activities Activity[]
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, dayNumber])
}

model Activity {
  id            String           @id @default(cuid())
  dayId         String
  order         Int
  title         String
  description   String?
  location      String?
  mapsUrl       String?
  category      ActivityCategory @default(OTHER)
  startTime     String?
  endTime       String?
  estimatedCost Float?
  isCustomized  Boolean          @default(false)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  day           Day              @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Hotel {
  id            String    @id @default(cuid())
  tripId        String    @unique
  name          String
  address       String?
  mapsUrl       String?
  checkIn       DateTime?
  checkOut      DateTime?
  pricePerNight Float?
  totalCost     Float?
  stars         Int?
  bookingUrl    String?
  notes         String?
  isCustomized  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  trip          Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Transportation {
  id            String        @id @default(cuid())
  tripId        String        @unique
  mode          TransportMode
  provider      String?
  departureFrom String?
  arrivalTo     String?
  estimatedCost Float?
  budgetNote    String?
  notes         String?
  isCustomized  Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  tripId    String   @unique
  rating    Int
  title     String?
  body      String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trophy {
  id          String       @id @default(cuid())
  key         TrophyKey    @unique
  name        String
  description String
  icon        String
  xp          Int          @default(10)
  users       UserTrophy[]
}

model UserTrophy {
  id        String   @id @default(cuid())
  userId    String
  trophyId  String
  awardedAt DateTime @default(now())
  trophy    Trophy   @relation(fields: [trophyId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trophyId])
}

enum Plan {
  FREE
  NOMAD
  GLOBETROTTER
}

enum TripType {
  ROMANTIC
  ADVENTUROUS
  FAMILY
  CULTURAL
  RELAXATION
  BUSINESS
  SOLO
}

enum BudgetLevel {
  LOW
  MEDIUM
  HIGH
}

enum TripStatus {
  GENERATING
  DRAFT
  CONFIRMED
  COMPLETED
}

enum ActivityCategory {
  SIGHTSEEING
  FOOD
  ADVENTURE
  CULTURE
  RELAXATION
  SHOPPING
  TRANSPORT
  OTHER
}

enum TransportMode {
  FLIGHT
  TRAIN
  BUS
  CAR
  FERRY
  OTHER
}

enum TrophyKey {
  FIRST_TRIP
  THIRD_TRIP
  TEN_TRIPS
  FIRST_REVIEW
  ADVENTURER
  ROMANTIC
  CONTINENT_HOPPER
  WORLD_EXPLORER
  BUDGET_MASTER
  LUXURY_TRAVELER
  TRIP_EDITOR
}
